# Backend Environment Variables (สำหรับ Render)
# คัดลอกไฟล์นี้เป็น .env สำหรับ local dev

# Port ที่ server ฟัง (Render จะตั้งให้อัตโนมัติ)
PORT=3000

# URL ของ backend เอง (ใส่ Render URL หลัง deploy)
BACKEND_URL=https://YOUR-RENDER-APP.onrender.com

# URL ของ frontend (ใส่ Vercel URL หลัง deploy)
FRONTEND_URL=https://YOUR-VERCEL-APP.vercel.app

# Firebase Service Account Key (วาง JSON ทั้งก้อนเป็น single line)
# วิธีได้ค่า: Firebase Console → Project Settings → Service Accounts → Generate new private key
# แล้ว minify JSON แล้ววางตรงนี้ (ห้าม commit ค่านี้จริงๆ)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
